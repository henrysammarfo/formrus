# Production/mainnet-facing FORMRUS config.
# These VITE_* values are public client configuration. Do not put private keys here.

# Server-side Walrus publisher used for form schemas, responses, and media uploads.
# Keep this secret. Do not prefix it with VITE_.
# This can be a Nami publisher endpoint or your own authenticated Walrus publisher.
WALRUS_PUBLISHER_URL=https://your-auth-publisher.example.com
WALRUS_EPOCHS=5
WALRUS_MAX_EPOCHS=5
WALRUS_MAX_PUBLISH_BYTES=52428800
WALRUS_RATE_LIMIT_MAX_WRITES=5
WALRUS_RATE_LIMIT_WINDOW_MS=60000
WALRUS_ALLOWED_CONTENT_TYPES=application/json,image/*,video/*,application/pdf,text/plain,text/csv

# Optional for self-sponsored authenticated Walrus publishers.
# Configure the Walrus publisher with the same decode secret.
# Use a random 32+ byte secret; hex strings with 0x prefix are decoded as bytes.
WALRUS_PUBLISHER_JWT_SECRET=0xYOUR_RANDOM_32_BYTE_HEX_SECRET
WALRUS_PUBLISHER_JWT_EXP_SECONDS=60
WALRUS_PUBLISHER_SEND_OBJECT_TO=0xYOUR_SPONSOR_WALLET_ADDRESS

# Public read endpoint for loading Walrus blobs.
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
VITE_WALRUS_EPOCHS=5
VITE_MAX_FILE_MB=3
VITE_MAX_VIDEO_MB=20
VITE_MAX_FILES_PER_RESPONSE=2
VITE_ALLOWED_UPLOAD_MIME_TYPES=image/*,video/*,application/pdf,text/plain,text/csv,application/json

# Optional official Seal SDK path for private forms.
# VITE_SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io:443
# VITE_SEAL_PACKAGE_ID=0x...
# VITE_SEAL_KEY_SERVERS=0xserver1,0xserver2
# VITE_SEAL_THRESHOLD=1
# VITE_SEAL_VERIFY_KEY_SERVERS=true
# VITE_SEAL_APPROVE_TARGET=0xpackage::module::seal_approve
# VITE_SEAL_REGISTER_TARGET=0xpackage::module::register_form
# VITE_SEAL_ADD_ADMIN_TARGET=0xpackage::module::add_form_admin
# VITE_SEAL_APPROVE_POLICY_OBJECT_ID=0x...
# VITE_SEAL_APPROVE_ARGUMENTS=id,policy
# VITE_SEAL_SESSION_TTL_MIN=10
